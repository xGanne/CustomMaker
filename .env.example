# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NÃO deve ser commitado no repositório.

# Token da API do ImgChest (obrigatório para upload)
# Obtenha em: https://imgchest.com/
IMG_CHEST_API_TOKEN=seu_token_aqui

# Chave da API Gemini (opcional — habilita a aba IA)
# Obtenha em: https://aistudio.google.com/
GEMINI_API_KEY=sua_chave_aqui
